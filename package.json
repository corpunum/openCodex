{
  "name": "opencodex",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous coding assistant with web UI - no approvals required",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node tests/run.js",
    "e2e:model-catalog": "node tests/e2e/model-catalog.e2e.js",
    "e2e:webui": "node tests/e2e/webui-chat.e2e.js",
    "e2e:webui-contract": "node tests/e2e/webui-contract.e2e.js",
    "e2e": "npm run e2e:model-catalog && npm run e2e:webui && npm run e2e:webui-contract"
  },
  "keywords": [
    "autonomous",
    "coding",
    "agent",
    "ai"
  ],
  "author": "Antonis",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0",
    "node-fetch": "^3.3.2",
    "better-sqlite3": "^11.3.0",
    "playwright": "^1.45.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
